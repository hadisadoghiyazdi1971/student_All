# Paths
DATA_DIR=./data
TAXONOMY_DIR=./data/taxonomy
CACHE_DIR=./cache
RUNTIME_DIR=./runtime
APP_SETTINGS_PROFILE=default

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_KEEP_ALIVE=10m
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.1
LLM_ANALYSIS_MAX_CHARS=10000
LLM_PROPOSAL_MAX_CHARS=9000

# Embedding and retrieval
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=16
# Set false only for temporary smoke tests. No embedding file will be read or written.
EMBEDDING_DISK_CACHE=true
# 0 means all articles. Use a small value together with disabled cache for a fast test run.
ARTICLE_CORPUS_LIMIT=0
# cpu, cuda, mps or leave empty for auto detection
EMBEDDING_DEVICE=
HF_HOME=./cache/huggingface
ARTICLE_SEMANTIC_WEIGHT=0.88
MIN_ROUTING_SCORE=50

# Upload and OCR
MAX_UPLOAD_MB=15
MAX_EXTRACTED_CHARS=250000
OCR_LANGUAGES=fas+eng
OCR_SCANNED_PDF=true
PDF_TEXT_MIN_CHARS=40
OCR_MAX_PDF_PAGES=20
# Windows example:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Logging
LOG_LEVEL=INFO
LOG_MAX_BYTES=5000000
LOG_BACKUP_COUNT=5
